<?xml version="1.0" encoding="utf-8"?>
<!--
    Step 8b sub-step 2.7: dark-mode-first widget with descriptive captions.

    Visual hierarchy:
      1. Header — line badge, → direction · from user stop, scheduled→estimated
      2. Route gauge bitmap — windowed (last 5 stops + user stop)
      3. Stop labels — leftmost-visible | ★ user stop
      4. Stops-away caption (conditional) — "Bus is 6 stops away"
      5. Bottom row — left: "Estimated arrival" caption + hero ETA stacked;
                       right: time-scale gauge + delta label
      6. GPS age caption (conditional) — "Bus position · 12s ago"
      7. Deviation pill (conditional)

    Colours are hardcoded for dark mode (BUG-020 deferred). Light-mode
    support is filed as a low-priority refinement to be revisited in
    Step 10 polish.

    RemoteViews supports basic LinearLayout / TextView / ImageView; no
    ConstraintLayout / CardView. Tap anywhere on the root opens MainActivity.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="#1E1E1E">

    <!-- 1. Header row — line badge + destination only. The scheduled-clock
         info that previously lived in a header right slot moved into a
         labeled caption above the time-scale gauge, where the schedule-
         conformance story (scheduled→predicted, scale gauge, delta) reads
         as one connected block instead of three scattered numbers. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_line_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:background="#1976D2"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:text="—"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/widget_destination"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:textSize="13sp"
            android:textColor="#E0E0E0"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="→ off-window"
            tools:ignore="HardcodedText" />
    </LinearLayout>

    <!-- 2. Route line — Canvas bitmap. 28dp tall so the bus marker (radius
         11dp + 1.5dp outline = 12.5dp from center) doesn't get clipped at
         top/bottom; previous 22dp left ~1.5dp clipped each side. -->
    <ImageView
        android:id="@+id/widget_route"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:layout_marginTop="6dp"
        android:scaleType="fitXY"
        android:contentDescription="@string/widget_route_content_description" />

    <!-- 3. Stop labels — leftmost-visible + ★ user stop. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/widget_first_stop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="start"
            android:textSize="10sp"
            android:textColor="#9E9E9E"
            android:singleLine="true"
            android:ellipsize="end"
            android:text=""
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/widget_user_stop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginStart="6dp"
            android:text=""
            tools:ignore="HardcodedText" />
    </LinearLayout>

    <!-- 4. Stops-away caption (visible only when bus is out of the 5-stop window). -->
    <TextView
        android:id="@+id/widget_stops_away"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginTop="3dp"
        android:textSize="11sp"
        android:textColor="#FFB74D"
        android:singleLine="true"
        android:ellipsize="end"
        android:text=""
        tools:ignore="HardcodedText" />

    <!-- 5. Bottom row — hero on left (caption + ETA stacked), schedule-
         conformance block on right (scheduled-arrival caption + scale
         gauge + delta). Both sides are vertical stacks for visual symmetry. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp">

        <!-- Left: hero caption + ETA. -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_hero_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#9E9E9E"
                android:text="@string/widget_hero_label" />

            <TextView
                android:id="@+id/widget_eta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="—"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <!-- Right: scheduled-arrival caption + (scale gauge + delta). -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/widget_scheduled_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:textSize="10sp"
                android:textColor="#9E9E9E"
                android:singleLine="true"
                android:text=""
                tools:ignore="HardcodedText" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <ImageView
                    android:id="@+id/widget_time_scale"
                    android:layout_width="68dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="6dp"
                    android:scaleType="fitXY"
                    android:contentDescription="@string/widget_time_scale_content_description" />

                <TextView
                    android:id="@+id/widget_delta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#BDBDBD"
                    android:singleLine="true"
                    android:text=""
                    tools:ignore="HardcodedText" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 5d. Next-departures line (BUG-028): "Next: 18:42 · 18:47" — upcoming
         scheduled times after the hero. GONE when there's none (low-frequency
         lines or end of day) or in Dormant / Passed phases. Helps high-
         frequency-line users decide what to do if they miss the current bus. -->
    <TextView
        android:id="@+id/widget_next_departures"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginTop="2dp"
        android:textSize="11sp"
        android:textColor="#BDBDBD"
        android:singleLine="true"
        android:ellipsize="end"
        android:text=""
        tools:ignore="HardcodedText" />

    <!-- 6. GPS-age caption (Chronometer auto-ticks every second inside the
         launcher's process — the displayed age progresses smoothly between
         widget pushes instead of sitting frozen for 20s. format gets %s
         replaced with elapsed time as MM:SS or H:MM:SS). -->
    <Chronometer
        android:id="@+id/widget_gps_age"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginTop="2dp"
        android:gravity="end"
        android:textSize="10sp"
        android:textColor="#9E9E9E"
        android:singleLine="true"
        android:format="@string/widget_gps_age_format"
        tools:ignore="HardcodedText" />

    <!-- 7. Deviation pill — full-width amber bar; GONE when no deviation. -->
    <TextView
        android:id="@+id/widget_deviation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginTop="4dp"
        android:padding="4dp"
        android:background="#FFB300"
        android:textColor="#000000"
        android:textSize="11sp"
        android:singleLine="true"
        android:ellipsize="end"
        android:text=""
        tools:ignore="HardcodedText" />
</LinearLayout>
