<?xml version="1.0" encoding="utf-8"?>
<!--
    Step 8b sub-step 2: text + Canvas-rendered gauges.

    Visual hierarchy from the design handoff (top to bottom):
      1. Header row — line badge, arrow, destination, scheduled time slot
      2. Route line — Canvas-rendered bitmap (stops + user-stop dot + bus marker)
      3. Stop labels — first stop, user's stop bold with star, last stop
      4. Bottom row — hero ETA, time-scale gauge bitmap, delta label
      5. Deviation pill — full-width amber bar; GONE when no deviation applies

    RemoteViews supports a limited set of view types — TextView, ImageView,
    Button, FrameLayout, LinearLayout, RelativeLayout, GridLayout, ListView,
    ProgressBar. No CardView / ConstraintLayout.

    Tap anywhere on the widget root opens MainActivity (covers half of P1-FR11).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="?android:attr/colorBackground">

    <!-- 1. Header row. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_line_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:background="#1976D2"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:text="—"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/widget_destination"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorPrimary"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="→ off-window"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/widget_scheduled"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="?android:attr/textColorSecondary"
            android:fontFamily="monospace"
            android:text=""
            tools:ignore="HardcodedText" />
    </LinearLayout>

    <!-- 2. Route line — Canvas bitmap. ~24dp tall; ImageView scales to fit. -->
    <ImageView
        android:id="@+id/widget_route"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:layout_marginTop="6dp"
        android:scaleType="fitXY"
        android:contentDescription="@string/widget_route_content_description" />

    <!-- 3. Stop labels — small text under the route line. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/widget_first_stop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="start"
            android:textSize="10sp"
            android:textColor="?android:attr/textColorSecondary"
            android:singleLine="true"
            android:ellipsize="end"
            android:text=""
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/widget_user_stop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:text=""
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/widget_last_stop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:textSize="10sp"
            android:textColor="?android:attr/textColorSecondary"
            android:singleLine="true"
            android:ellipsize="end"
            android:text=""
            tools:ignore="HardcodedText" />
    </LinearLayout>

    <!-- 4. Bottom row — hero ETA + time-scale + delta label. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/widget_eta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="—"
            tools:ignore="HardcodedText" />

        <ImageView
            android:id="@+id/widget_time_scale"
            android:layout_width="72dp"
            android:layout_height="20dp"
            android:layout_marginEnd="6dp"
            android:scaleType="fitXY"
            android:contentDescription="@string/widget_time_scale_content_description" />

        <TextView
            android:id="@+id/widget_delta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:singleLine="true"
            android:text=""
            tools:ignore="HardcodedText" />
    </LinearLayout>

    <!-- 5. Deviation pill — visible when state.deviation != null. -->
    <TextView
        android:id="@+id/widget_deviation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginTop="4dp"
        android:padding="4dp"
        android:background="#FFB300"
        android:textColor="#000000"
        android:textSize="11sp"
        android:singleLine="true"
        android:ellipsize="end"
        android:text=""
        tools:ignore="HardcodedText" />
</LinearLayout>
